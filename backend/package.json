{
  "name": "foundit-backend",
  "version": "1.0.0",
  "description": "Backend for FoundIt VIT lost and found system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:store-to-mongo": "node scripts/migrateStoreToMongo.js"
  },
  "nodemonConfig": {
    "ignore": [
      "data/*.json",
      "uploads/*"
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "mongodb-memory-server": "^10.1.4",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}